# Конфигурация API для конвертера спецификаций
# 
# Выберите один из провайдеров и раскомментируйте соответствующий блок

# ============================================================================
# ВАРИАНТ 1: ANTHROPIC API (оригинальный)
# ============================================================================
# Получите ключ на: https://console.anthropic.com/
# 
# API_PROVIDER = 'anthropic'
# ANTHROPIC_API_KEY = 'sk-ant-api03-...'
# MODEL_NAME = 'claude-sonnet-4-20250514'


# ============================================================================
# ВАРИАНТ 2: OPENROUTER (рекомендуется - дешевле и проще)
# ============================================================================
# Получите ключ на: https://openrouter.ai/keys
# 
API_PROVIDER = 'openrouter'
OPENROUTER_API_KEY = 'sk-or-v1-...'  # ← Вставьте ваш ключ здесь
MODEL_NAME = 'anthropic/claude-sonnet-4'  # Claude через OpenRouter

# Альтернативные модели через OpenRouter:
# MODEL_NAME = 'anthropic/claude-opus-4'     # Максимальная точность
# MODEL_NAME = 'openai/gpt-4-turbo'          # GPT-4 (тоже хорошо работает)
# MODEL_NAME = 'google/gemini-pro-1.5'       # Google Gemini


# ============================================================================
# ВАРИАНТ 3: OPENAI API
# ============================================================================
# Получите ключ на: https://platform.openai.com/api-keys
# 
# API_PROVIDER = 'openai'
# OPENAI_API_KEY = 'sk-...'
# MODEL_NAME = 'gpt-4-turbo'


# ============================================================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# ============================================================================

# Максимальное количество токенов в ответе (больше = дороже, но лучше для больших таблиц)
MAX_TOKENS = 4000

# Таймаут запроса в секундах
REQUEST_TIMEOUT = 120

# Включить детальное логирование
DEBUG = True
