# Конфигурация для Anthropic API
# 
# Получите API ключ на https://console.anthropic.com/

API_KEY = 'sk-ant-your-key-here'
API_PROVIDER = 'anthropic'
MODEL_NAME = 'claude-sonnet-4-20250514'

# Доступные модели Anthropic:
# - claude-sonnet-4-20250514 (рекомендуется, баланс цена/качество)
# - claude-opus-4-5-20251101 (лучшая точность, дороже)
# - claude-haiku-4-5-20251001 (быстрее и дешевле, чуть ниже точность)

