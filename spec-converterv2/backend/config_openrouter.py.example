# Конфигурация для OpenRouter API
# 
# Получите API ключ на https://openrouter.ai/
# Замените 'your-api-key-here' на ваш реальный ключ

OPENROUTER_API_KEY = 'REDACTED_OPENROUTER_KEY'

# Выберите модель:
# Рекомендуется Claude Sonnet 4 для лучшего качества
MODEL_NAME = 'anthropic/claude-sonnet-4'

# Другие варианты моделей:
# MODEL_NAME = 'anthropic/claude-3.5-sonnet'  # Чуть дешевле
# MODEL_NAME = 'openai/gpt-4-vision-preview'  # Альтернатива от OpenAI
# MODEL_NAME = 'google/gemini-pro-vision'     # Дешевле, но может хуже с кириллицей

# Пример корректно заполненного конфига:
# OPENROUTER_API_KEY = 'sk-or-v1-abc123...'
# MODEL_NAME = 'anthropic/claude-sonnet-4'
