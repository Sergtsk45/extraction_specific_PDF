# ============================================================
# Конфигурация API для конвертера спецификаций PDF → Excel
# Скопируйте этот файл в .env и заполните реальный ключ
# ============================================================

# Выберите провайдера: anthropic | openrouter | openai
API_PROVIDER=openrouter

# OpenRouter (рекомендуется — дешевле и проще, доступны все модели)
# Получите ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic (оригинальный провайдер)
# Получите ключ: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI
# Получите ключ: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Модель (примеры):
# anthropic/claude-sonnet-4   — лучшее соотношение цена/качество через OpenRouter
# anthropic/claude-opus-4     — максимальная точность
# openai/gpt-4-turbo          — альтернатива через OpenRouter
MODEL_NAME=anthropic/claude-sonnet-4

# Макс. токенов в ответе (16000 рекомендуется для больших таблиц)
MAX_TOKENS=16000

# Разрешённые CORS-источники (через запятую)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5001

# Таймаут HTTP-запросов к LLM API (секунды)
REQUEST_TIMEOUT_SEC=120

# Отключить буферизацию stdout (для Docker/systemd)
PYTHONUNBUFFERED=1
